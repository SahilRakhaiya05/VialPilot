# LLM — Cerebras primary, Gemini fallback
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=auto

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Application
APP_MODE=development
PORT=7860
DATABASE_URL=sqlite:///data/vialpilot.db
UPLOAD_DIR=data/uploads
MAX_VIDEO_FRAMES=8
MAX_VISION_FRAMES=4
ENABLE_PIPELINE_ANALYZER=true
DASH_PORT=8050

# Robot simulator: auto | robot | lab_bench
SIMULATOR_MODE=auto
ROBOT_TASK_NAME=visual_manipulation
ROBOT_DISPLAY_GUI=false
ROBOT_OBS_DIR=data/robot_observations

# Hardware bridge (optional)
HARDWARE_MODE=simulation
MQTT_BROKER_URL=
WEBHOOK_COMMAND_URL=

# Public links (shown in nav/footer)
DOCS_SITE_URL=https://vialpilot-swarm.vercel.app
GITHUB_REPO_URL=https://github.com/SahilRakhaiya05/VialPilot